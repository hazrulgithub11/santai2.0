NODE_ENV=development
HOST=127.0.0.1
PORT=3000
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info
TRUST_PROXY=0

# Local Tuya (LAN). Never expose TUYA_LOCAL_KEY to the frontend.
TUYA_DEVICE_ID=
TUYA_LOCAL_KEY=
TUYA_DEVICE_IP=
# Optional. Default 6668.
TUYA_DEVICE_PORT=6668
# Default 3.4. Wrong version breaks LAN control; UDP discovery (below) can override from the device.
TUYA_PROTOCOL_VERSION=3.4
TUYA_POWER_DP=1
# Default true. Listens on UDP 6666/6667 to learn the plug's LAN IP + protocol (TuyAPI find()).
# Set to 0 if discovery must be disabled (e.g. restricted container network).
TUYA_UDP_DISCOVER=1
