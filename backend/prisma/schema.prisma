// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Placeholder so the first migration can run. Replace with your domain models when ready.
model SchemaBootstrap {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
}
